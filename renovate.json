{
  "$schema": "https://docs.renovatebot.com/renovate-schema.json",
  "extends": [
    "config:recommended",
  ],
  "semanticCommits": "enabled",
  "labels": ["dependencies"],
  "dependencyDashboard": true,
  "groupName": "all",
  "timezone": "Europe/Berlin",
  "schedule": [
    "* 0-4 * * 1"
  ],
  "packageRules": [
    {
      "description": "Group all Helm chart dependency updates",
      "matchManagers": ["helmv3"],
      "groupName": "helm dependencies",
      "groupSlug": "helm-deps"
    },
    {
      "description": "Group Docker image updates from values.yaml",
      "matchManagers": ["helm-values"],
      "groupName": "container images",
      "groupSlug": "container-images"
    }
  ]
}
